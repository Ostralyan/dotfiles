{
    "profiles": [
        {
            "name": "Default profile",
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps Lock to Hyper (Ctrl+Shift+Opt+Cmd) when held, Escape when tapped alone",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": {
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "set_variable": {
                                            "name": "hyper",
                                            "value": 1
                                        }
                                    },
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": [
                                            "left_command",
                                            "left_control",
                                            "left_option"
                                        ]
                                    }
                                ],
                                "to_after_key_up": [
                                    {
                                        "set_variable": {
                                            "name": "hyper",
                                            "value": 0
                                        }
                                    }
                                ],
                                "to_if_alone": [
                                    {
                                        "key_code": "escape"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        }
    ]
}
