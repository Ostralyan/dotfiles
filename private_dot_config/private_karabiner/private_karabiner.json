{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps Lock to Hyper (Ctrl+Shift+Opt+Cmd) when held, Escape when tapped alone",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "set_variable": { "name": "hyper", "value": 1 } },
                                    {
                                        "key_code": "left_shift",
                                        "modifiers": ["left_command", "left_control", "left_option"]
                                    },
                                    { "shell_command": "/opt/homebrew/bin/sketchybar --set hyper icon.background.color=0xfff9e2af icon.color=0xff1e1e2e label='Hyper' label.color=0xfff9e2af label.padding_left=6" }
                                ],
                                "to_after_key_up": [
                                    { "set_variable": { "name": "hyper", "value": 0 } },
                                    { "set_variable": { "name": "hyper_g", "value": 0 } },
                                    { "shell_command": "~/.config/karabiner/assets/hyper_release.sh" }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper + g -> leader for 'g' chords",
                        "manipulators": [
                            {
                                "conditions": [
                                    { "name": "hyper", "type": "variable_if", "value": 1 }
                                ],
                                "from": {
                                    "key_code": "g",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "set_variable": { "name": "hyper_g", "value": 1 } },
                                    { "shell_command": "/opt/homebrew/bin/sketchybar --set hyper label='g...'" }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Hyper + g, h -> stage GitHub action",
                        "manipulators": [
                            {
                                "conditions": [
                                    { "name": "hyper", "type": "variable_if", "value": 1 },
                                    { "name": "hyper_g", "type": "variable_if", "value": 1 }
                                ],
                                "from": {
                                    "key_code": "h",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    { "set_variable": { "name": "hyper_g", "value": 0 } },
                                    { "shell_command": "echo gh > /tmp/hyper_action && /opt/homebrew/bin/sketchybar --set hyper label='gh -> GitHub'" }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}