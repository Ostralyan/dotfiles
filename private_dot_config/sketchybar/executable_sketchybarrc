)
sketchybar --default "${default[@]}"

##### Aerospace Workspaces #####
sketchybar --add event aerospace_workspace_change

source "$PLUGIN_DIR/icon_map.sh"

SPACE_NAMES=()
FOCUSED="$(aerospace list-workspaces --focused)"
OCCUPIED="$(aerospace list-workspaces --monitor all --empty no)"

for sid in $(aerospace list-workspaces --all); do
  SPACE_NAMES+=(space.$sid)
  ICON="$sid"
  LABEL="$(workspace_name "$sid")"

  SHOW=off
  if echo "$OCCUPIED" | grep -qx "$sid" || [ "$sid" = "$FOCUSED" ]; then
    SHOW=on
  fi

  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      icon="$ICON" \
      drawing="$SHOW" \
      icon.padding_left=10 \
      icon.padding_right=10 \
      background.drawing=off \
      label.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

sketchybar --add item workspace_name left \
