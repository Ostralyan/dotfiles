##### Popup helper function #####
add_popup_line() {
  local PARENT=$1 ITEM=$2 COLOR=$3
  sketchybar --add item $ITEM popup.$PARENT \
             --set $ITEM \
                   icon.drawing=off \
                   label.font="FantasqueSansM Nerd Font Mono:Bold:12.0" \
                   label.color=$COLOR \
                   label.padding_left=10 \
                   label.padding_right=10 \
                   background.drawing=off \
                   background.border_width=0
}

setup_popup() {
  local PARENT=$1 COLOR=$2
  sketchybar --set $PARENT popup.drawing=off \
             --subscribe $PARENT mouse.entered mouse.exited \
             --set $PARENT \
                   popup.background.color=0xff1e1e2e \
                   popup.background.corner_radius=10 \
                   popup.background.border_width=2 \
                   popup.background.border_color=$COLOR
}

